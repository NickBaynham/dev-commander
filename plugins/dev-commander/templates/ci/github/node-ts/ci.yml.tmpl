name: {{project_name}} CI
on: [push, pull_request]
jobs:
  ci:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "22"
      - run: make install
      - run: make lint
      - run: make test
      - run: make build
      - name: dependency scan
        run: npm audit --audit-level=high
      - name: secret scan
        uses: gitleaks/gitleaks-action@v2
