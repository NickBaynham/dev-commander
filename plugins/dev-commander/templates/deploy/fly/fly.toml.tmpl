app = "{{project_name}}"
primary_region = "iad"

[build]
  image = "ghcr.io/{{repo_owner}}/{{project_name}}:latest"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true

[[http_service.checks]]
  interval = "30s"
  timeout = "5s"
  path = "/"
